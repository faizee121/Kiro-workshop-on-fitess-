# Copy this file to .env and fill in real values. Never commit .env.

# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret

# Amazon DocumentDB connection
# When tunneling through a bastion, host is typically localhost
DOCDB_HOST=localhost
DOCDB_PORT=27017
DOCDB_USERNAME=your-docdb-user
DOCDB_PASSWORD=your-docdb-password
DOCDB_DATABASE=fitness_center

# Path to the downloaded Amazon RDS/DocumentDB CA bundle
DOCDB_TLS_CA_FILE=global-bundle.pem
